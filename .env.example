# Local development — use your LAN IP on a physical phone (NOT localhost).
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.5:3000
# Android emulator: EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# Production — point to your Railway API service (HTTPS, no port number).
# Must be the Node API (server/), NOT the Expo dev server.
# Example: EXPO_PUBLIC_API_URL=https://king-cric-production.up.railway.app
EXPO_PUBLIC_API_URL=https://your-api.up.railway.app

# Optional: only needed for push notifications in development/production builds (not Expo Go)
# EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-uuid

# Server env vars — set these in Railway dashboard (Variables tab), NOT in this file.
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/king-cric
# JWT_SECRET=use-a-long-random-secret-here
# PORT=3000
# CORS_ORIGIN=*
